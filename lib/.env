# fixed (tetap) atau percentage (persentase)
DIGIFLAZZ_MARKUP_VALUE=500
# Jika fixed: dalam Rupiah, jika percentage: dalam persen (misal: 5 untuk 5%)

# Auto sync configuration
DIGIFLAZZ_AUTO_SYNC=true
DIGIFLAZZ_SYNC_INTERVAL=3600000
# Interval sync dalam milidetik (default: 1 jam = 3600000ms)

# Webhook URL (opsional, kosongkan jika tidak ada)
